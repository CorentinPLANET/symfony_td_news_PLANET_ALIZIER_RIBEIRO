{% extends 'base.html.twig' %}

{% block title %}Schedule index{% endblock %}

{% block body %}
    <h1>Schedule index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Matine</th>
                <th>Cours</th>
                <th>Professeur</th>
                <th>Salle</th>
                <th>Specialite</th>
                <th>Dates</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for schedule in schedules %}
            <tr>
                <td>{{ schedule.id }}</td>
                <td>{{ schedule.matine ? 'Yes' : 'No' }}</td>
                <td>{{ schedule.cours }}</td>
                <td>{{ schedule.professeur }}</td>
                <td>{{ schedule.salle }}</td>
                <td>{{ schedule.specialite }}</td>
                <td>{{ schedule.dates ? schedule.dates|date('Y-m-d') : '' }}</td>
                <td>
                    <a href="{{ path('app_schedule_show', {'id': schedule.id}) }}">show</a>
                    <a href="{{ path('app_schedule_edit', {'id': schedule.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_schedule_new') }}">Create new</a>
{% endblock %}
