{% extends 'base.html.twig' %}

{% block title %}Schedule index
{% endblock %}

{% block body %}
	<h1>Schedule index</h1>

	<table class="table">
		<thead>
			<th>Cours</th>
			<th>Professeur</th>
			<th>Salle</th>
			<th>Specialite</th>
			<th>Dates</th>
			<th>Matine</th>
			<th>Promo</th>
			<th>actions</th>
		</thead>
	</tr>
</thead>
<tbody>
	{% for schedule in schedules %}
		<tr>
			<td>{{ schedule.cours }}</td>
			<td>{{ schedule.professeur }}</td>
			<td>{{ schedule.salle }}</td>
			<td>{{ schedule.specialite }}</td>
			<td>{{ schedule.dates ? schedule.dates|date('d-m-Y') : '' }}</td>
			<td>{{ schedule.matine.name}}</td>
			<td>{{ schedule.promo.name }}</td>
			<td>
				<a href="{{ path('app_schedule_show', {'id': schedule.id}) }}">show</a>
				<a href="{{ path('app_schedule_edit', {'id': schedule.id}) }}">edit</a>
			</td>
		</tr>
	{% else %}
		<tr>
			<td colspan="8">no records found</td>
		</tr>
	{% endfor %}
</tbody></table><a href="{{ path('app_schedule_new') }}">Create new</a>{% endblock %}
