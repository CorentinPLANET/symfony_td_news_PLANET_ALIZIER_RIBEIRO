{% extends 'base.html.twig' %}

{% block title %}Schedule
{% endblock %}

{% block body %}
	<h1>Schedule</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Cours</th>
				<td>{{ schedule.cours }}</td>
			</tr>
			<tr>
				<th>Professeur</th>
				<td>{{ schedule.professeur }}</td>
			</tr>
			<tr>
				<th>Salle</th>
				<td>{{ schedule.salle }}</td>
			</tr>
			<tr>
				<th>Specialite</th>
				<td>{{ schedule.specialite }}</td>
			</tr>
			<tr>
				<th>Dates</th>
				<td>{{ schedule.dates ? schedule.dates|date('d-m-Y') : '' }}</td>
			</tr>
			<tr>
				<th>Matine</th>
				<td>{{ schedule.matine.name }}</td>
			</tr>
			<th>Promo</th>
			<td>{{ schedule.promo.name}}</td>
		</tbody>
	</tr>
</tbody></table><a href="{{ path('app_schedule_index') }}">back to list</a><a href="{{ path('app_schedule_edit', {'id': schedule.id}) }}">edit</a>{{ include('schedule/_delete_form.html.twig') }}{% endblock %}
